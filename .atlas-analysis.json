  "keyFeatures": [
    "Cron-based task scheduling with intuitive frequency methods",
    "Decorator-based scheduling on AdonisJS commands",
    "Prevent overlapping task executions with built-in locking",
    "Tag-based schedule filtering and organization",
    "Timezone support for international deployments",
    "Hot-reloading during development with --watch flag",
    "Lifecycle hooks for before/after task execution",
    "CLI commands for running and listing scheduled tasks"
  ],
  "publicApiSurface": [
    "scheduler.command(name, args)",
    "scheduler.call(callback)",
    "scheduler.withoutOverlapping(callback, config)",
    "scheduler.withTag(callback, tag)",
    "@schedule(expression, args)",
    "Worker.start()",
    "Worker.stop()",
    "node ace scheduler:run",
    "node ace scheduler:work",
    "node ace scheduler:list",
    ".everyMinute()",
    ".everyFiveMinutes()",
    ".hourly()",
    ".daily()",
    ".weekly()",
    ".cron(expression)",
    ".withoutOverlapping()",
    ".timezone(timezone)",
    ".tag(tag)",
    ".immediate()",
